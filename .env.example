# ================================
# Family Hub — משתני סביבה
# ================================
# קובץ זה הוא דוגמה — אל תמלא כאן ערכים אמיתיים!
# ב-Railway: הוסף את הערכים תחת Variables

# --- Database (Railway יוצר אוטומטית) ---
DATABASE_URL=postgresql://user:password@host:5432/familyhub

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://YOUR-RAILWAY-URL/auth/google/callback

# --- JWT ---
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- OpenWeatherMap ---
OPENWEATHER_API_KEY=your-api-key
WEATHER_CITY=Ashdod
WEATHER_COUNTRY=IL
WEATHER_LANG=he

# --- iCloud Calendar (CalDAV) ---
ICLOUD_USERNAME=your-apple-id@icloud.com
ICLOUD_APP_PASSWORD=your-app-specific-password
# אופציונלי — אם יש כמה יומנים בחשבון, לאיזה מהם ליצור אירועים חדשים (שם מדויק).
# בלי זה, אירועים חדשים (למשל מטלגרם) נכתבים ליומן הראשון שמוחזר מהחשבון.
ICLOUD_CALENDAR_NAME=
# אופציונלי — אם יש כמה יומנים בעלי שם זהה (למשל כמה יומנים שכולם נקראים "Family") וICLOUD_CALENDAR_NAME
# לא מספיק כדי להבדיל ביניהם: מספר אינדקס (0,1,2...) לפי הסדר מ-GET /calendar/calendars. גובר על ICLOUD_CALENDAR_NAME.
ICLOUD_CALENDAR_INDEX=

# --- Claude API ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_FAMILY_CHAT_ID=your-family-chat-id
# מחרוזת אקראית משלך — מגדירים אותה גם כ-secret_token בקריאת setWebhook (ראו הוראות README/קומיט).
# מונעת מכל מי שמוצא את כתובת ה-webhook ליצור משימות בשמכם.
TELEGRAM_WEBHOOK_SECRET=choose-a-random-secret-string

# --- App ---
FRONTEND_URL=https://YOUR-LOVABLE-URL
ENVIRONMENT=production
